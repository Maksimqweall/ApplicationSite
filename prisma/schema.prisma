generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String?  // Сделали необязательным (добавили знак вопроса)
  googleId     String?  @unique // Новое поле для привязки Google аккаунта
  email        String?  @unique // Поле для email (опционально, но полезно)
  bio         String?
  location    String?
  telegram    String?
  github      String?
  photo       String?
  // --- НОВЫЕ ПОЛЯ ---
  calorieGoal Int       @default(2500)
  weight      Float?
  height      Float?
  // ------------------
  workouts    Workout[]
  meals       Meal[]
}

model Workout {
  id        Int      @id @default(autoincrement())
  title     String
  notes     String?
  date      String   @default("") // Формат: YYYY-MM-DD
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Meal {
  id        Int      @id @default(autoincrement())
  itemName  String
  calories  Int
  date      String   @default("") // Формат: YYYY-MM-DD
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}